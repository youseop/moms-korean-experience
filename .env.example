# Public canonical site URL — used in metadata (metadataBase, OG tags),
# sitemap.xml, and robots.txt.
#
# Local dev: leave unset, falls back to http://localhost:3000
# Vercel preview: set per preview deployment if you want shareable OG previews.
# Vercel production: set once to the final domain (Vercel-assigned URL or
# your custom domain, e.g. https://eunjungs-table.vercel.app).
NEXT_PUBLIC_SITE_URL=

# Resend transactional email — required to actually send inquiries.
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Where inquiries are delivered (defaults to youseop@speakbridges.com if unset)
INQUIRY_TO_EMAIL=youseop@speakbridges.com

# From line — using Resend's sandbox sender for v1 (no domain verification needed).
# Replace with a verified domain sender once a custom domain is set up.
INQUIRY_FROM_EMAIL=Eunjung's Table <onboarding@resend.dev>

# Set to 1 to skip the actual Resend call (used by Playwright tests; useful in CI).
INQUIRY_DRY_RUN=
