# Public canonical site URL — used in metadata (metadataBase, OG tags),
# sitemap.xml, and robots.txt.
#
# Local dev: leave unset, falls back to http://localhost:3000
# Vercel preview: set per preview deployment if you want shareable OG previews.
# Vercel production: set once to the final domain (Vercel-assigned URL or
# your custom domain, e.g. https://eunjungs-table.vercel.app).
NEXT_PUBLIC_SITE_URL=
